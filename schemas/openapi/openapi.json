{
  "components": {
    "schemas": {
      "AuditEvent": {
        "properties": {
          "created_at": {
            "type": "string"
          },
          "event_id": {
            "type": "string"
          },
          "event_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "target_type": {
            "type": "string"
          }
        },
        "required": [
          "event_id",
          "event_type",
          "status",
          "created_at"
        ],
        "type": "object"
      },
      "CitedResult": {
        "properties": {
          "citations": {
            "items": {
              "type": "object"
            },
            "type": "array"
          },
          "rank": {
            "type": "integer"
          },
          "score": {
            "type": "number"
          },
          "snippet": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "target_type": {
            "type": "string"
          }
        },
        "required": [
          "target_id",
          "snippet",
          "citations"
        ],
        "type": "object"
      },
      "ErrorEnvelope": {
        "properties": {
          "code": {
            "type": "string"
          },
          "details": {
            "type": "object"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error",
          "code"
        ],
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "degraded_reasons": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "runtime_implemented": {
            "const": false,
            "type": "boolean"
          },
          "schema_version": {
            "type": "string"
          },
          "status": {
            "enum": [
              "ok",
              "degraded",
              "failed"
            ]
          }
        },
        "required": [
          "status",
          "schema_version",
          "runtime_implemented"
        ],
        "type": "object"
      },
      "IngestRunResponse": {
        "properties": {
          "audit_id": {
            "type": "string"
          },
          "source_counts": {
            "type": "object"
          },
          "status": {
            "enum": [
              "succeeded",
              "degraded",
              "failed"
            ]
          }
        },
        "required": [
          "status",
          "source_counts"
        ],
        "type": "object"
      },
      "RecallRequest": {
        "properties": {
          "limit": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer"
          },
          "query": {
            "type": "string"
          },
          "scope": {
            "type": "object"
          }
        },
        "required": [
          "query"
        ],
        "type": "object"
      },
      "RecallResponse": {
        "properties": {
          "missing_sources": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "query": {
            "type": "string"
          },
          "query_id": {
            "type": "string"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/CitedResult"
            },
            "type": "array"
          },
          "source_coverage": {
            "type": "object"
          },
          "status": {
            "enum": [
              "ok",
              "degraded",
              "abstain",
              "unauthorized",
              "error"
            ]
          }
        },
        "required": [
          "query",
          "status",
          "source_coverage",
          "results"
        ],
        "type": "object"
      },
      "SourceRecord": {
        "properties": {
          "authority_level": {
            "enum": [
              "primary",
              "secondary",
              "derived",
              "untrusted"
            ]
          },
          "display_name": {
            "type": "string"
          },
          "external_ref": {
            "type": "string"
          },
          "failure_reason": {
            "type": "string"
          },
          "freshness_seconds": {
            "minimum": 0,
            "type": "integer"
          },
          "health": {
            "enum": [
              "unknown",
              "healthy",
              "degraded",
              "unavailable",
              "unauthorized",
              "disabled"
            ]
          },
          "overflow_kind": {
            "enum": [
              "memory_md",
              "user_md",
              "honcho",
              "session",
              "wiki",
              "repo",
              "xbrain"
            ]
          },
          "profile_id": {
            "type": "string"
          },
          "read_authority": {
            "enum": [
              "none",
              "read_only",
              "read_sensitive"
            ]
          },
          "source_id": {
            "type": "string"
          },
          "source_type": {
            "enum": [
              "hermes_state_db",
              "hermes_profile_memory",
              "hermes_markdown_overflow",
              "honcho",
              "session_search",
              "obsidian_wiki",
              "repo_docs",
              "xbrain",
              "council_core",
              "file",
              "api",
              "manual",
              "tool",
              "system"
            ]
          },
          "write_authority": {
            "enum": [
              "none",
              "propose_only",
              "write_allowed"
            ]
          }
        },
        "required": [
          "source_id",
          "source_type",
          "authority_level",
          "read_authority",
          "write_authority",
          "health"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Contract-only OpenAPI target. Runtime API is not implemented yet.",
    "title": "Mnemoir Provenance API",
    "version": "0.2.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/audit/events": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "events": {
                      "items": {
                        "$ref": "#/components/schemas/AuditEvent"
                      },
                      "type": "array"
                    }
                  },
                  "required": [
                    "events"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Target audit event response"
          }
        },
        "summary": "List audit events"
      }
    },
    "/council/items": {
      "get": {
        "responses": {
          "200": {
            "description": "Target council items response"
          }
        },
        "summary": "List council items"
      },
      "post": {
        "responses": {
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Write policy disabled"
          }
        },
        "summary": "Create council item; disabled until write policy exists"
      }
    },
    "/health": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Target health response"
          }
        },
        "summary": "Health check"
      }
    },
    "/ingest/run": {
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestRunResponse"
                }
              }
            },
            "description": "Target ingestion result"
          }
        },
        "summary": "Run bounded ingestion from configured sources"
      }
    },
    "/recall": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecallRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecallResponse"
                }
              }
            },
            "description": "Target cited recall packet"
          }
        },
        "summary": "Source-grounded recall query"
      }
    },
    "/sources": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "sources": {
                      "items": {
                        "$ref": "#/components/schemas/SourceRecord"
                      },
                      "type": "array"
                    }
                  },
                  "required": [
                    "sources"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Target source registry response"
          }
        },
        "summary": "List source registry"
      }
    }
  }
}
